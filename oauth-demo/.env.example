PORT=3200
SESSION_SECRET=replace-with-a-long-random-string

# OAuth server base URL. Example production value: https://api.qysyw.cn
OAUTH_BASE_URL=http://localhost:10001

# Optional separate authorize page host. Leave empty to reuse OAUTH_BASE_URL.
# Useful when the login/consent page is served from a different site than the API.
OAUTH_AUTHORIZE_BASE_URL=

# Create an approved OAuth client in the main site first.
OAUTH_CLIENT_ID=your-client-id
OAUTH_CLIENT_SECRET=your-client-secret

# Must exactly match one registered redirect URI on the OAuth client.
OAUTH_REDIRECT_URI=http://localhost:3200/oauth/callback

# Space-separated scopes. profile is enough for /users/me.
OAUTH_SCOPE=profile
